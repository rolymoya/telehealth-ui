#!/usr/bin/env bash
# git post-commit hook: when a commit lands on a feature branch with a
# docs/features/<branch>.md, append a "Commit log (auto-appended)" entry
# (SHA + date + subject + diff stat) and fold it into the same commit
# via `git commit --amend --no-edit --no-verify`.
#
# Why post-commit (and not pre-commit / prepare-commit-msg):
#  - pre-commit can stage files into the commit, but the commit message
#    isn't available yet, so we can't write the subject.
#  - prepare-commit-msg has the message but git has already snapshotted
#    the tree by then — `git add` here updates the index but doesn't
#    land in the commit.
#  - post-commit has both SHA and message; the amend re-snapshots the
#    tree to include the MD update under the same logical commit.
#
# The amend rewrites the commit (new SHA, same message + tree+1 file).
# That's fine because the amend happens locally before any push.
#
# Recursion: our own amend re-triggers post-commit. The env-var guard
# below makes the second run a no-op.
#
# Caveats:
#  - If the MD file had unstaged user edits before the commit, the amend
#    will fold those edits in alongside our auto entry. Stage or stash
#    them first if you don't want that.
#  - Skipped for: merges, default branches, branches without a matching
#    docs/features/<branch>.md, and when the same subject already
#    appears in the recent auto-log (catches user-initiated amends).

set -u

if [ -n "${_FEATURE_LOG_AMEND_IN_PROGRESS:-}" ]; then
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
branch="$(git -C "$repo_root" rev-parse --abbrev-ref HEAD 2>/dev/null)" || exit 0

case "$branch" in
  main|master|develop|dev|trunk|HEAD) exit 0 ;;
esac

target_file="$repo_root/docs/features/$branch.md"
[ -f "$target_file" ] || exit 0

# Skip merge commits (multiple parents).
parent_count="$(git -C "$repo_root" cat-file -p HEAD 2>/dev/null | grep -c '^parent ')"
[ "${parent_count:-0}" -gt 1 ] && exit 0

sha="$(git -C "$repo_root" rev-parse --short HEAD 2>/dev/null)" || exit 0
subject="$(git -C "$repo_root" log -1 --pretty=%s HEAD 2>/dev/null)" || exit 0
author_date="$(git -C "$repo_root" log -1 --pretty=%ad --date=iso-strict HEAD 2>/dev/null)" || exit 0
stat="$(git -C "$repo_root" show --stat --format= HEAD 2>/dev/null)"

[ -n "$sha" ] && [ -n "$subject" ] || exit 0

section_header="## Commit log (auto-appended)"

# Idempotency: if the same subject already appears in the recent
# auto-log entries, skip (handles user-initiated amends and reruns).
if sed -n "/^${section_header}\$/,\$p" "$target_file" 2>/dev/null \
    | tail -n 40 \
    | grep -qF -- "$subject"; then
  exit 0
fi

if ! grep -qF "$section_header" "$target_file" 2>/dev/null; then
  {
    printf '\n'
    printf '%s\n' "$section_header"
    printf '\n'
    printf '_Auto-generated by .githooks/post-commit on each `git commit`. Newest entries at the bottom._\n'
  } >> "$target_file"
fi

{
  printf '\n'
  printf '### %s · %s\n' "$sha" "$author_date"
  printf '\n'
  printf '%s\n' "$subject"
  if [ -n "$stat" ]; then
    printf '\n'
    printf '```\n'
    printf '%s\n' "$stat"
    printf '```\n'
  fi
} >> "$target_file"

git -C "$repo_root" add "$target_file" >/dev/null 2>&1

_FEATURE_LOG_AMEND_IN_PROGRESS=1 \
  git -C "$repo_root" commit --amend --no-edit --no-verify >/dev/null 2>&1

exit 0
