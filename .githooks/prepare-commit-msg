#!/usr/bin/env bash
# git prepare-commit-msg hook: when committing on a feature branch with
# a docs/features/<branch>.md, append a "Commit log (auto-appended)"
# entry (date + subject + staged diff stat) and `git add` the MD file
# so it lands in the same commit.
#
# Why prepare-commit-msg (and not pre-commit): we need the commit
# message to be available, which it is in $1 by the time this hook
# fires. The index is still mutable here — `git add` updates it before
# the commit object is built.
#
# Skips: merges, squashes, amends, template/reuse sources, default
# branches, missing per-branch MD files, editor-driven commits where the
# subject isn't yet known.

set -u

msg_file="${1:-}"
source="${2:-}"
amend_sha="${3:-}"

[ -n "$msg_file" ] && [ -f "$msg_file" ] || exit 0
[ -z "$amend_sha" ] || exit 0

case "$source" in
  merge|squash|template|commit) exit 0 ;;
esac

# Editor-driven commits arrive here with an empty source and only the
# message template in the file. We can't extract a real subject yet, so
# skip rather than write a placeholder.
if [ -z "$source" ]; then
  if ! grep -v '^[[:space:]]*#' "$msg_file" 2>/dev/null | grep -qE '[^[:space:]]'; then
    exit 0
  fi
fi

repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
branch="$(git -C "$repo_root" rev-parse --abbrev-ref HEAD 2>/dev/null)" || exit 0

case "$branch" in
  main|master|develop|dev|trunk|HEAD) exit 0 ;;
esac

target_file="$repo_root/docs/features/$branch.md"
[ -f "$target_file" ] || exit 0

subject="$(grep -v '^[[:space:]]*#' "$msg_file" 2>/dev/null \
  | sed -E 's/^[[:space:]]+//; s/[[:space:]]+$//' \
  | grep -v '^$' \
  | head -1)"

[ -n "$subject" ] || exit 0

stat="$(git -C "$repo_root" diff --cached --stat 2>/dev/null)"
author_date="$(date +%Y-%m-%dT%H:%M:%S%z | sed -E 's/([+-][0-9]{2})([0-9]{2})$/\1:\2/')"

section_header="## Commit log (auto-appended)"

if sed -n "/^${section_header}\$/,\$p" "$target_file" 2>/dev/null \
    | tail -n 40 \
    | grep -qF -- "$subject"; then
  : # already logged this subject; just re-stage in case the file is dirty
else
  if ! grep -qF "$section_header" "$target_file" 2>/dev/null; then
    {
      printf '\n'
      printf '%s\n' "$section_header"
      printf '\n'
      printf '_Auto-generated by .githooks/prepare-commit-msg on each `git commit`. Newest entries at the bottom._\n'
    } >> "$target_file"
  fi

  {
    printf '\n'
    printf '### %s\n' "$author_date"
    printf '\n'
    printf '%s\n' "$subject"
    if [ -n "$stat" ]; then
      printf '\n'
      printf '```\n'
      printf '%s\n' "$stat"
      printf '```\n'
    fi
  } >> "$target_file"
fi

git -C "$repo_root" add "$target_file" >/dev/null 2>&1

exit 0
