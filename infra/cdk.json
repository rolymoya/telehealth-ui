{
  "app": "npx ts-node --prefer-ts-exts bin/apoth.ts",
  "watch": {
    "include": ["**"],
    "exclude": [
      "README.md",
      "cdk*.json",
      "**/*.d.ts",
      "**/*.js",
      "tsconfig*.json",
      "package*.json",
      "node_modules",
      "test"
    ]
  },
  "context": {
    "@aws-cdk/aws-apigateway:usagePlanKeyOrderInsensitiveId": true,
    "@aws-cdk/aws-cloudfront:defaultSecurityPolicyTLSv1.2_2021": true,
    "@aws-cdk/aws-rds:lowercaseDbIdentifier": true,
    "@aws-cdk/core:stackRelativeExports": true,
    "staging": {
      "account": "FILL_ME_IN",
      "region": "us-east-1",
      "natGateways": 1,
      "rdsMultiAz": false,
      "redisReplicas": 0,
      "kmsKeyArn": "FILL_ME_IN"
    },
    "prod": {
      "account": "FILL_ME_IN",
      "region": "us-east-1",
      "natGateways": 2,
      "rdsMultiAz": true,
      "redisReplicas": 1,
      "kmsKeyArn": "FILL_ME_IN"
    }
  }
}
