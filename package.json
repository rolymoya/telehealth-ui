{
  "name": "telehealth-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:static": "node scripts/build-static.mjs",
    "patient:dev": "vite --config patient-app/vite.config.ts",
    "patient:build": "vite build --config patient-app/vite.config.ts",
    "patient:preview": "vite preview --config patient-app/vite.config.ts",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "mdi:docs": "node scripts/mdi-docs/extract-postman.mjs",
    "mdi:docs:validate": "node scripts/mdi-docs/validate-generated.mjs",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright show-report",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:ui": "playwright test --ui",
    "test:watch": "vitest"
  },
  "dependencies": {
    "aws-jwt-verify": "^5.2.1",
    "next": "^16.2.6",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-router-dom": "^7.18.1",
    "stripe": "^22.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "jsdom": "^29.1.1",
    "postcss": "8.5.10",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^8.1.2",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "postcss": "8.5.10",
    "undici": "7.28.0"
  }
}
