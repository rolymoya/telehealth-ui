# Local development — copy to .env.local and fill in values.
# Never commit real credentials.

# Option A: direct connection string (local dev / CI)
DATABASE_URL=postgresql://apoth:apoth@localhost:5432/apoth

# Option B: Secrets Manager ARN (App Runner / ECS runtime)
# When DATABASE_URL is absent, client.ts fetches this secret and constructs
# the connection string from the returned JSON { username, password, host, port, dbname }.
DB_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:apoth/db-XXXXXX

# AWS region (required when using DB_SECRET_ARN path)
AWS_REGION=us-east-1
